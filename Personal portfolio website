<title>My Portfolio</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
    scroll-behavior:smooth;
}

body{
    background:#f4f4f4;
    color:#333;
}

/* Navigation */
nav{
    position:fixed;
    top:0;
    width:100%;
    background:#222;
    padding:15px 50px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    z-index:1000;
}

nav h2{
    color:#fff;
}

nav ul{
    display:flex;
    list-style:none;
}

nav ul li{
    margin-left:25px;
}

nav ul li a{
    text-decoration:none;
    color:#fff;
    transition:.3s;
}

nav ul li a:hover{
    color:#00d4ff;
}

/* Home */
#home{
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:linear-gradient(135deg,#4facfe,#00f2fe);
    color:white;
    text-align:center;
    flex-direction:column;
    padding:20px;
}

#home img{
    width:180px;
    height:180px;
    border-radius:50%;
    border:5px solid white;
    object-fit:cover;
    margin-bottom:20px;
}

#home h1{
    font-size:48px;
}

#home p{
    margin-top:15px;
    font-size:20px;
    max-width:700px;
}

/* Sections */
section{
    padding:80px 10%;
}

h2{
    text-align:center;
    margin-bottom:30px;
    color:#0077cc;
}

/* About */
.about-box{
    background:white;
    padding:30px;
    border-radius:10px;
    box-shadow:0 5px 15px rgba(0,0,0,.1);
}

/* Skills */
.skills{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(150px,1fr));
    gap:20px;
}

.skill{
    background:white;
    padding:20px;
    text-align:center;
    border-radius:10px;
    box-shadow:0 5px 15px rgba(0,0,0,.1);
    transition:.3s;
}

.skill:hover{
    transform:translateY(-5px);
}

/* Projects */
.projects{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:20px;
}

.project{
    background:white;
    padding:20px;
    border-radius:10px;
    box-shadow:0 5px 15px rgba(0,0,0,.1);
}

.project h3{
    margin-bottom:10px;
}

/* Timeline */
.timeline{
    background:white;
    padding:30px;
    border-radius:10px;
    box-shadow:0 5px 15px rgba(0,0,0,.1);
}

.timeline div{
    margin-bottom:20px;
}

/* Contact */
.contact{
    text-align:center;
}

.contact a{
    color:#0077cc;
    text-decoration:none;
}

/* Footer */
footer{
    background:#222;
    color:white;
    text-align:center;
    padding:20px;
}

/* Responsive */
@media(max-width:768px){
    nav{
        flex-direction:column;
    }

    nav ul{
        margin-top:10px;
    }

    #home h1{
        font-size:34px;
    }

    #home p{
        font-size:18px;
    }
}
</style>

</head>
